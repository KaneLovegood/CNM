<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700&family=Space+Grotesk:wght@500;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <div class="background-layer"></div>
    <nav class="navbar navbar-expand-lg border-bottom sticky-top app-navbar">
      <div class="container">
        <a class="navbar-brand fw-bold" href="/">Trang chủ</a>
        <a class="btn btn-accent" href="/products/new">+ Thêm sản phẩm</a>
      </div>
    </nav>

    <main class="container py-4 py-lg-5">
      <% if (successMessage) { %>
      <div class="alert alert-success shadow-sm"><%= successMessage %></div>
      <% } %> <% if (errorMessage) { %>
      <div class="alert alert-danger shadow-sm"><%= errorMessage %></div>
      <% } %>
