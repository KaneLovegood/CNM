<% if (errors && errors.length > 0) { %>
<div class="alert alert-danger">
  <ul class="mb-0">
    <% errors.forEach((error) => { %>
    <li><%= error %></li>
    <% }) %>
  </ul>
</div>
<% } %>

<form action="<%= action %>" method="POST" enctype="multipart/form-data" class="card border-0 shadow-sm">
  <% if (method && method !== 'POST') { %>
  <input type="hidden" name="_method" value="<%= method %>" />
  <% } %>

  <div class="card-body p-4">
    <div class="mb-3">
      <label for="name" class="form-label">Tên sản phẩm</label>
      <input
        id="name"
        name="name"
        type="text"
        class="form-control"
        required
        value="<%= product.name %>"
      />
    </div>

    <div class="row g-3">
      <div class="col-md-6">
        <label for="price" class="form-label">Giá</label>
        <input
          id="price"
          name="price"
          type="number"
          min="0"
          step="0.01"
          class="form-control"
          required
          value="<%= product.price %>"
        />
      </div>
      <div class="col-md-6">
        <label for="unit_in_stock" class="form-label">Số lượng tồn</label>
        <input
          id="unit_in_stock"
          name="unit_in_stock"
          type="number"
          min="0"
          step="1"
          class="form-control"
          required
          value="<%= product.unit_in_stock %>"
        />
      </div>
    </div>

    <div class="mt-3 mb-2">
      <label for="url_image" class="form-label">Hình ảnh (JPG, PNG, GIF, WEBP)</label>
      <input id="url_image" name="url_image" type="file" class="form-control" accept="image/*" />
    </div>

    <% if (product.url_image) { %>
    <div class="mb-3">
      <p class="mb-2 text-muted">Ảnh hiện tại:</p>
      <img src="<%= product.url_image %>" alt="Current image" class="detail-image" />
    </div>
    <% } %>
  </div>

  <div class="card-footer bg-white border-0 d-flex gap-2 justify-content-end pb-4 px-4">
    <a class="btn btn-outline-secondary" href="/">Quay lại</a>
    <button class="btn btn-primary" type="submit"><%= submitText %></button>
  </div>
</form>
