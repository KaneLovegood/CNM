<%- include('../partials/header', { pageTitle }) %>

<div class="card border-0 shadow-sm overflow-hidden">
  <div class="row g-0">
    <div class="col-lg-5 p-4 bg-light d-flex align-items-center justify-content-center">
      <% if (product.url_image) { %>
      <img src="<%= product.url_image %>" alt="<%= product.name %>" class="detail-image" />
      <% } else { %>
      <div class="detail-image placeholder-thumb">No image</div>
      <% } %>
    </div>
    <div class="col-lg-7">
      <div class="card-body p-4 p-lg-5">
        <span class="badge text-bg-info mb-3">ID: <%= product.id %></span>
        <h1 class="h2 mb-3"><%= product.name %></h1>
        <p class="mb-2"><strong>Giá:</strong> <%= Number(product.price).toLocaleString('vi-VN') %> đ</p>
        <p class="mb-4"><strong>Số lượng tồn:</strong> <%= product.unit_in_stock %></p>

        <div class="d-flex flex-wrap gap-2">
          <a href="/" class="btn btn-outline-secondary">Quay lại</a>
          <a href="/products/<%= product.id %>/edit" class="btn btn-warning">Chỉnh sửa</a>
          <form
            action="/products/<%= product.id %>?_method=DELETE"
            method="POST"
            onsubmit="return confirm('Bạn có chắc muốn xóa sản phẩm này?')"
          >
            <button class="btn btn-danger">Xóa sản phẩm</button>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
